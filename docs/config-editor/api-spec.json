{
  "openapi": "3.0.0",
  "info": {
    "title": "Prism Config Editor API",
    "version": "1.0.0",
    "description": "REST API for reading and writing Claude configuration files (~/.claude/*.md and project-local CLAUDE.md). All file paths are server-side allowlisted; no user-supplied paths are accepted. Security boundary: opaque file IDs only."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local Prism server"
    }
  ],
  "tags": [
    {
      "name": "config",
      "description": "Config file management endpoints"
    }
  ],
  "paths": {
    "/api/v1/config/files": {
      "get": {
        "operationId": "listConfigFiles",
        "summary": "List all available config files",
        "description": "Returns an array of config file descriptors. The server rebuilds the registry on each call by reading ~/.claude/ (for global files) and checking process.cwd()/CLAUDE.md (for the project file). Files are returned in order: global files alphabetically, then project files.",
        "tags": ["config"],
        "responses": {
          "200": {
            "description": "Successfully listed config files.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ConfigFileDescriptor"
                  }
                },
                "examples": {
                  "typical": {
                    "summary": "Two global files and one project file",
                    "value": [
                      {
                        "id": "global-claude-md",
                        "name": "CLAUDE.md",
                        "scope": "global",
                        "directory": "~/.claude",
                        "sizeBytes": 9900,
                        "modifiedAt": "2026-03-18T12:00:00.000Z"
                      },
                      {
                        "id": "global-rtk-md",
                        "name": "RTK.md",
                        "scope": "global",
                        "directory": "~/.claude",
                        "sizeBytes": 964,
                        "modifiedAt": "2026-03-17T10:00:00.000Z"
                      },
                      {
                        "id": "project-claude-md",
                        "name": "CLAUDE.md",
                        "scope": "project",
                        "directory": "./",
                        "sizeBytes": 2500,
                        "modifiedAt": "2026-03-18T11:00:00.000Z"
                      }
                    ]
                  },
                  "globalOnly": {
                    "summary": "No project CLAUDE.md exists",
                    "value": [
                      {
                        "id": "global-claude-md",
                        "name": "CLAUDE.md",
                        "scope": "global",
                        "directory": "~/.claude",
                        "sizeBytes": 9900,
                        "modifiedAt": "2026-03-18T12:00:00.000Z"
                      }
                    ]
                  },
                  "empty": {
                    "summary": "No config files found",
                    "value": []
                  }
                }
              }
            },
            "headers": {
              "X-Response-Time": {
                "description": "Server processing time in milliseconds. SLA: < 50ms.",
                "schema": { "type": "string", "example": "12ms" }
              }
            }
          }
        }
      }
    },
    "/api/v1/config/files/{fileId}": {
      "get": {
        "operationId": "getConfigFile",
        "summary": "Read a config file's content",
        "description": "Returns the full content of the specified config file. The fileId is validated against the server-side registry; only pre-registered file IDs are accepted. If the physical file does not exist on disk, a 404 is returned even if the ID would normally be valid.",
        "tags": ["config"],
        "parameters": [
          {
            "$ref": "#/components/parameters/fileId"
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully read the config file.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigFileContent"
                },
                "examples": {
                  "globalClaudeMd": {
                    "summary": "Reading ~/.claude/CLAUDE.md",
                    "value": {
                      "id": "global-claude-md",
                      "name": "CLAUDE.md",
                      "scope": "global",
                      "content": "# Agent Team Workflow\n\nThis project uses four specialized agents in a sequential pipeline...",
                      "sizeBytes": 9900,
                      "modifiedAt": "2026-03-18T12:00:00.000Z"
                    }
                  },
                  "projectClaudeMd": {
                    "summary": "Reading ./CLAUDE.md",
                    "value": {
                      "id": "project-claude-md",
                      "name": "CLAUDE.md",
                      "scope": "project",
                      "content": "# Prism — Project Rules\n\n## Design System (MANDATORY)...",
                      "sizeBytes": 2500,
                      "modifiedAt": "2026-03-18T11:00:00.000Z"
                    }
                  }
                }
              }
            },
            "headers": {
              "X-Response-Time": {
                "description": "Server processing time in milliseconds. SLA: < 100ms.",
                "schema": { "type": "string", "example": "8ms" }
              }
            }
          },
          "404": {
            "description": "The fileId was not found in the server registry, or the physical file does not exist on disk.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "unknownId": {
                    "summary": "fileId not in registry",
                    "value": {
                      "error": {
                        "code": "FILE_NOT_FOUND",
                        "message": "Config file 'global-unknown-md' was not found.",
                        "suggestion": "Refresh the file list and try again. Only files returned by GET /api/v1/config/files are accessible."
                      }
                    }
                  },
                  "missingOnDisk": {
                    "summary": "File registered but missing on disk",
                    "value": {
                      "error": {
                        "code": "FILE_NOT_FOUND",
                        "message": "Config file 'project-claude-md' was not found on disk.",
                        "suggestion": "The file CLAUDE.md may have been deleted. Create it manually and refresh."
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "saveConfigFile",
        "summary": "Write (overwrite) a config file",
        "description": "Atomically overwrites the specified config file with the provided content. Uses a .tmp file + fs.renameSync pattern to prevent partial writes. The fileId is validated against the server-side registry before any write is attempted. An empty string is a valid content value (clears the file). Content is encoded as UTF-8.",
        "tags": ["config"],
        "parameters": [
          {
            "$ref": "#/components/parameters/fileId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SaveConfigFileRequest"
              },
              "examples": {
                "typical": {
                  "summary": "Saving updated CLAUDE.md content",
                  "value": {
                    "content": "# Agent Team Workflow (updated)\n\nThis project uses four specialized agents..."
                  }
                },
                "clearFile": {
                  "summary": "Clearing a file (empty string is valid)",
                  "value": {
                    "content": ""
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File saved successfully. Returns updated metadata (no content echo).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigFileSaveResult"
                },
                "examples": {
                  "saved": {
                    "summary": "Successful save",
                    "value": {
                      "id": "global-claude-md",
                      "name": "CLAUDE.md",
                      "scope": "global",
                      "sizeBytes": 10200,
                      "modifiedAt": "2026-03-18T13:00:00.000Z"
                    }
                  }
                }
              }
            },
            "headers": {
              "X-Response-Time": {
                "description": "Server processing time in milliseconds. SLA: < 200ms.",
                "schema": { "type": "string", "example": "15ms" }
              }
            }
          },
          "400": {
            "description": "Request body is missing or malformed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "missingContent": {
                    "summary": "content field absent",
                    "value": {
                      "error": {
                        "code": "VALIDATION_ERROR",
                        "message": "The 'content' field is required and must be a string.",
                        "suggestion": "Send a JSON body with a 'content' field: { \"content\": \"...\" }",
                        "field": "content"
                      }
                    }
                  },
                  "invalidType": {
                    "summary": "content is not a string",
                    "value": {
                      "error": {
                        "code": "VALIDATION_ERROR",
                        "message": "The 'content' field must be a string, not a number or object.",
                        "suggestion": "Ensure the value of 'content' is a plain text string.",
                        "field": "content"
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "The fileId was not found in the server registry.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "unknownId": {
                    "summary": "fileId not in registry",
                    "value": {
                      "error": {
                        "code": "FILE_NOT_FOUND",
                        "message": "Config file 'global-unknown-md' was not found.",
                        "suggestion": "Refresh the file list and try again. Only files returned by GET /api/v1/config/files can be saved."
                      }
                    }
                  }
                }
              }
            }
          },
          "413": {
            "description": "Content exceeds the 1 MB maximum allowed size.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "tooLarge": {
                    "summary": "Content exceeds 1 MB",
                    "value": {
                      "error": {
                        "code": "PAYLOAD_TOO_LARGE",
                        "message": "File content exceeds the 1 MB limit (received 1.5 MB).",
                        "suggestion": "Config files should be under 1 MB. Consider splitting the content into multiple files.",
                        "field": "content"
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Server error during the atomic write (e.g., filesystem permission denied).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "writeFailure": {
                    "summary": "Filesystem write failed",
                    "value": {
                      "error": {
                        "code": "WRITE_FAILED",
                        "message": "Could not save CLAUDE.md. The file system may be read-only or permissions may be insufficient.",
                        "suggestion": "Check that the file is not locked by another application and that you have write permissions to ~/.claude/."
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "fileId": {
        "name": "fileId",
        "in": "path",
        "required": true,
        "description": "Opaque file identifier. Generated deterministically by the server using the pattern: {scope}-{filename-kebab-without-extension}-md. Example: 'global-claude-md', 'global-rtk-md', 'project-claude-md'. Must be a value previously returned by GET /api/v1/config/files.",
        "schema": {
          "type": "string",
          "pattern": "^(global|project)-[a-z0-9-]+-md$",
          "examples": ["global-claude-md", "global-rtk-md", "project-claude-md"]
        }
      }
    },
    "schemas": {
      "ConfigFileDescriptor": {
        "type": "object",
        "description": "Metadata about a config file (no content). Returned by the list endpoint.",
        "required": ["id", "name", "scope", "directory", "sizeBytes", "modifiedAt"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Opaque file identifier. Use this ID when calling GET/PUT /api/v1/config/files/{fileId}.",
            "example": "global-claude-md",
            "pattern": "^(global|project)-[a-z0-9-]+-md$"
          },
          "name": {
            "type": "string",
            "description": "Human-readable filename, including the .md extension.",
            "example": "CLAUDE.md"
          },
          "scope": {
            "type": "string",
            "enum": ["global", "project"],
            "description": "Whether the file lives in ~/.claude/ (global) or the Prism project root (project).",
            "example": "global"
          },
          "directory": {
            "type": "string",
            "description": "Human-readable directory label. '~/.claude' for global files, './' for project files. Not a filesystem path — do not use for path construction.",
            "example": "~/.claude"
          },
          "sizeBytes": {
            "type": "integer",
            "minimum": 0,
            "description": "File size in bytes at the time of the list request.",
            "example": 9900
          },
          "modifiedAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of the last modification (from fs.stat mtime).",
            "example": "2026-03-18T12:00:00.000Z"
          }
        }
      },
      "ConfigFileContent": {
        "type": "object",
        "description": "A config file with its full text content. Returned by the read endpoint.",
        "required": ["id", "name", "scope", "content", "sizeBytes", "modifiedAt"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Opaque file identifier.",
            "example": "global-claude-md"
          },
          "name": {
            "type": "string",
            "description": "Human-readable filename.",
            "example": "CLAUDE.md"
          },
          "scope": {
            "type": "string",
            "enum": ["global", "project"],
            "example": "global"
          },
          "content": {
            "type": "string",
            "description": "Full UTF-8 text content of the file. May be an empty string if the file exists but is empty.",
            "example": "# Agent Team Workflow\n\nThis project uses four specialized agents..."
          },
          "sizeBytes": {
            "type": "integer",
            "minimum": 0,
            "description": "File size in bytes.",
            "example": 9900
          },
          "modifiedAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of the last modification.",
            "example": "2026-03-18T12:00:00.000Z"
          }
        }
      },
      "SaveConfigFileRequest": {
        "type": "object",
        "description": "Request body for overwriting a config file.",
        "required": ["content"],
        "properties": {
          "content": {
            "type": "string",
            "description": "New full UTF-8 text content to write to the file. Empty string is valid (clears the file). Maximum 1 MB (1,048,576 bytes as measured by Buffer.byteLength).",
            "maxLength": 1048576,
            "example": "# Agent Team Workflow (updated)\n\nThis project uses four specialized agents..."
          }
        }
      },
      "ConfigFileSaveResult": {
        "type": "object",
        "description": "Result returned after a successful save. Contains updated metadata; content is not echoed back.",
        "required": ["id", "name", "scope", "sizeBytes", "modifiedAt"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Opaque file identifier.",
            "example": "global-claude-md"
          },
          "name": {
            "type": "string",
            "description": "Human-readable filename.",
            "example": "CLAUDE.md"
          },
          "scope": {
            "type": "string",
            "enum": ["global", "project"],
            "example": "global"
          },
          "sizeBytes": {
            "type": "integer",
            "minimum": 0,
            "description": "New file size in bytes after the write.",
            "example": 10200
          },
          "modifiedAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of the write operation (server-generated).",
            "example": "2026-03-18T13:00:00.000Z"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "description": "Standard error envelope used by all config endpoints.",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "object",
            "required": ["code", "message"],
            "properties": {
              "code": {
                "type": "string",
                "description": "Machine-readable error code in SCREAMING_SNAKE_CASE.",
                "enum": [
                  "FILE_NOT_FOUND",
                  "VALIDATION_ERROR",
                  "PAYLOAD_TOO_LARGE",
                  "WRITE_FAILED"
                ],
                "example": "FILE_NOT_FOUND"
              },
              "message": {
                "type": "string",
                "description": "Human-readable error description. Non-technical — safe to display in the UI.",
                "example": "Config file 'global-unknown-md' was not found."
              },
              "suggestion": {
                "type": "string",
                "description": "Optional actionable guidance for the user on how to fix the problem.",
                "example": "Refresh the file list and try again."
              },
              "field": {
                "type": "string",
                "description": "Only present for VALIDATION_ERROR and PAYLOAD_TOO_LARGE. The name of the request body field that caused the error.",
                "example": "content"
              }
            }
          }
        }
      }
    }
  }
}
