{
  "openapi": "3.0.0",
  "info": {
    "title": "Prism Agent Launcher API",
    "version": "1.2.0",
    "description": "Endpoints for listing AI agents, generating prompts, injecting commands into the PTY terminal, and managing launcher settings. All endpoints are local-only (localhost:3000) — no authentication required.",
    "contact": {
      "name": "Prism"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local Prism server"
    }
  ],
  "tags": [
    {
      "name": "agents",
      "description": "Agent discovery and prompt generation"
    },
    {
      "name": "settings",
      "description": "Launcher CLI and pipeline settings"
    }
  ],
  "paths": {
    "/api/v1/agents": {
      "get": {
        "operationId": "listAgents",
        "summary": "List available agent definitions",
        "description": "Scans ~/.claude/agents/*.md and returns metadata for each agent file found. Returns an empty array if the directory does not exist. Response latency <100ms p99.",
        "tags": ["agents"],
        "responses": {
          "200": {
            "description": "List of available agents (may be empty).",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AgentInfo"
                  }
                },
                "examples": {
                  "withAgents": {
                    "summary": "Agents found",
                    "value": [
                      {
                        "id": "senior-architect",
                        "name": "senior-architect.md",
                        "displayName": "Senior Architect",
                        "path": "/Users/oscar/.claude/agents/senior-architect.md",
                        "sizeBytes": 11400
                      },
                      {
                        "id": "ux-api-designer",
                        "name": "ux-api-designer.md",
                        "displayName": "Ux Api Designer",
                        "path": "/Users/oscar/.claude/agents/ux-api-designer.md",
                        "sizeBytes": 8200
                      },
                      {
                        "id": "developer-agent",
                        "name": "developer-agent.md",
                        "displayName": "Developer Agent",
                        "path": "/Users/oscar/.claude/agents/developer-agent.md",
                        "sizeBytes": 6300
                      },
                      {
                        "id": "qa-engineer-e2e",
                        "name": "qa-engineer-e2e.md",
                        "displayName": "Qa Engineer E2e",
                        "path": "/Users/oscar/.claude/agents/qa-engineer-e2e.md",
                        "sizeBytes": 5800
                      }
                    ]
                  },
                  "empty": {
                    "summary": "No agents found",
                    "value": []
                  }
                }
              }
            }
          },
          "500": {
            "description": "Unexpected server error while scanning agent directory.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "AGENT_DIRECTORY_READ_ERROR",
                    "message": "Could not read the agents directory.",
                    "suggestion": "Check that ~/.claude/agents/ is accessible and has read permissions."
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/agents/{agentId}": {
      "get": {
        "operationId": "getAgent",
        "summary": "Get full content of a specific agent definition",
        "description": "Reads the content of ~/.claude/agents/{agentId}.md. Only serves files within the ~/.claude/agents/ directory (path traversal blocked). Response latency <100ms p99.",
        "tags": ["agents"],
        "parameters": [
          {
            "name": "agentId",
            "in": "path",
            "required": true,
            "description": "Kebab-case stem of the agent file (e.g. 'senior-architect' for 'senior-architect.md').",
            "schema": {
              "type": "string",
              "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
              "example": "senior-architect"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Agent found — returns metadata and full file content.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentDetail"
                },
                "example": {
                  "id": "senior-architect",
                  "name": "senior-architect.md",
                  "displayName": "Senior Architect",
                  "content": "# Senior Architect Agent\n\nYou are the Senior Architect..."
                }
              }
            }
          },
          "400": {
            "description": "Agent ID format is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "INVALID_AGENT_ID",
                    "message": "The agent ID provided is not valid.",
                    "suggestion": "Agent IDs must be lowercase kebab-case (e.g. 'senior-architect'). Check GET /api/v1/agents for valid IDs.",
                    "field": "agentId"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Path traversal attempt detected.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "FORBIDDEN_PATH",
                    "message": "Access to this agent file is not allowed.",
                    "suggestion": "Only agent files inside ~/.claude/agents/ can be read."
                  }
                }
              }
            }
          },
          "404": {
            "description": "Agent file not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "AGENT_NOT_FOUND",
                    "message": "No agent named 'senior-architect' was found.",
                    "suggestion": "Check that 'senior-architect.md' exists in ~/.claude/agents/. Use GET /api/v1/agents to see available agents."
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/agent/prompt": {
      "post": {
        "operationId": "generateAgentPrompt",
        "summary": "Generate an agent prompt and write it to a temp file",
        "description": "Assembles a full prompt from task data, agent file content, and standard instruction blocks (Kanban, Git, Project Context). Writes the prompt atomically to data/.prompts/ and returns the absolute file path plus a ready-to-execute CLI command string. Response latency <200ms p99.",
        "tags": ["agents"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PromptGenerationRequest"
              },
              "example": {
                "agentId": "senior-architect",
                "taskId": "abc-123",
                "spaceId": "4391dcb8-1234-5678-abcd-ef0123456789",
                "customInstructions": "Focus on scalability concerns.",
                "workingDirectory": "/Users/oscar/projects/prism"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Prompt generated and written to disk.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PromptGenerationResponse"
                },
                "example": {
                  "promptPath": "/Users/oscar/projects/prism/data/.prompts/prompt-1710795000000-abc123.md",
                  "promptPreview": "## TASK CONTEXT\nTitle: Define TypeScript types for agent launcher\nType: research\nColumn: todo\nSpace: agent-launcher\nAssigned: senior-architect\n\n## AGENT INSTRUCTIONS\n# Senior Architect Agent\n\nYou are the Senior Architect...",
                  "cliCommand": "claude -p \"$(cat /Users/oscar/projects/prism/data/.prompts/prompt-1710795000000-abc123.md)\" --allowedTools \"Agent,Bash,Read,Write,Edit,Glob,Grep\"",
                  "estimatedTokens": 2400
                }
              }
            }
          },
          "400": {
            "description": "Missing or invalid required fields.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "missingAgentId": {
                    "summary": "agentId missing",
                    "value": {
                      "error": {
                        "code": "VALIDATION_ERROR",
                        "message": "The 'agentId' field is required.",
                        "suggestion": "Provide the kebab-case agent ID (e.g. 'senior-architect'). Use GET /api/v1/agents to list available agents.",
                        "field": "agentId"
                      }
                    }
                  },
                  "missingTaskId": {
                    "summary": "taskId missing",
                    "value": {
                      "error": {
                        "code": "VALIDATION_ERROR",
                        "message": "The 'taskId' field is required.",
                        "suggestion": "Provide the ID of the task to use as context for the prompt.",
                        "field": "taskId"
                      }
                    }
                  },
                  "missingSpaceId": {
                    "summary": "spaceId missing",
                    "value": {
                      "error": {
                        "code": "VALIDATION_ERROR",
                        "message": "The 'spaceId' field is required.",
                        "suggestion": "Provide the space ID that contains the task.",
                        "field": "spaceId"
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Agent or task not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "agentNotFound": {
                    "summary": "Agent file missing",
                    "value": {
                      "error": {
                        "code": "AGENT_NOT_FOUND",
                        "message": "No agent named 'senior-architect' was found.",
                        "suggestion": "Check that 'senior-architect.md' exists in ~/.claude/agents/."
                      }
                    }
                  },
                  "taskNotFound": {
                    "summary": "Task not found in space",
                    "value": {
                      "error": {
                        "code": "TASK_NOT_FOUND",
                        "message": "Task 'abc-123' was not found in space '4391dcb8-...'.",
                        "suggestion": "Confirm the taskId and spaceId are correct. The task may have been moved or deleted."
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Prompt file could not be written to disk.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "PROMPT_WRITE_ERROR",
                    "message": "Could not write the prompt file to disk.",
                    "suggestion": "Check that data/.prompts/ is writable and the disk has available space."
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/settings": {
      "get": {
        "operationId": "getSettings",
        "summary": "Get current launcher settings",
        "description": "Reads data/settings.json. Returns full settings with defaults applied for any missing fields. If the settings file does not exist, returns the default configuration.",
        "tags": ["settings"],
        "responses": {
          "200": {
            "description": "Current settings (with defaults for any missing fields).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LauncherSettings"
                },
                "example": {
                  "cli": {
                    "tool": "claude",
                    "binary": "claude",
                    "flags": ["-p"],
                    "promptFlag": "-p",
                    "fileInputMethod": "cat-subshell"
                  },
                  "pipeline": {
                    "autoAdvance": true,
                    "confirmBetweenStages": true,
                    "stages": [
                      "senior-architect",
                      "ux-api-designer",
                      "developer-agent",
                      "qa-engineer-e2e"
                    ]
                  },
                  "prompts": {
                    "includeKanbanBlock": true,
                    "includeGitBlock": true,
                    "workingDirectory": ""
                  }
                }
              }
            }
          },
          "500": {
            "description": "Settings file could not be read.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "SETTINGS_READ_ERROR",
                    "message": "Could not read the settings file.",
                    "suggestion": "Check that data/settings.json is readable and contains valid JSON."
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateSettings",
        "summary": "Update launcher settings (partial merge)",
        "description": "Deep-merges the provided partial settings object with the existing settings and writes atomically to data/settings.json. Only provided fields are updated — omitted fields retain their current values.",
        "tags": ["settings"],
        "requestBody": {
          "required": true,
          "description": "Partial settings object. Only provided fields are updated.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LauncherSettingsPartial"
              },
              "examples": {
                "switchToOpenCode": {
                  "summary": "Switch CLI tool to opencode",
                  "value": {
                    "cli": {
                      "tool": "opencode",
                      "binary": "opencode"
                    }
                  }
                },
                "disableAutoAdvance": {
                  "summary": "Turn off pipeline auto-advance",
                  "value": {
                    "pipeline": {
                      "autoAdvance": false
                    }
                  }
                },
                "setWorkingDirectory": {
                  "summary": "Set working directory",
                  "value": {
                    "prompts": {
                      "workingDirectory": "/Users/oscar/projects/prism"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Settings updated — returns full merged settings.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LauncherSettings"
                }
              }
            }
          },
          "400": {
            "description": "Request body is missing or invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "emptyBody": {
                    "summary": "Empty body",
                    "value": {
                      "error": {
                        "code": "VALIDATION_ERROR",
                        "message": "The request body is empty or not valid JSON.",
                        "suggestion": "Send a partial settings object. Example: { \"cli\": { \"tool\": \"opencode\" } }"
                      }
                    }
                  },
                  "invalidTool": {
                    "summary": "Invalid CLI tool value",
                    "value": {
                      "error": {
                        "code": "VALIDATION_ERROR",
                        "message": "The value 'mycli' is not a valid CLI tool.",
                        "suggestion": "Use one of: 'claude', 'opencode', 'custom'. For a custom binary path, set cli.tool to 'custom' and cli.binary to the full path.",
                        "field": "cli.tool"
                      }
                    }
                  },
                  "invalidFileInputMethod": {
                    "summary": "Invalid fileInputMethod",
                    "value": {
                      "error": {
                        "code": "VALIDATION_ERROR",
                        "message": "The value 'pipe' is not a valid prompt delivery method.",
                        "suggestion": "Use one of: 'cat-subshell', 'stdin-redirect', 'flag-file'.",
                        "field": "cli.fileInputMethod"
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Settings could not be written to disk.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": {
                    "code": "SETTINGS_WRITE_ERROR",
                    "message": "Could not save the settings file.",
                    "suggestion": "Check that the data/ directory is writable."
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AgentInfo": {
        "type": "object",
        "description": "Metadata for an agent definition file discovered in ~/.claude/agents/.",
        "required": ["id", "name", "displayName", "path", "sizeBytes"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Kebab-case stem of the filename, used as the identifier in API calls.",
            "example": "senior-architect",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "name": {
            "type": "string",
            "description": "Full filename including .md extension.",
            "example": "senior-architect.md"
          },
          "displayName": {
            "type": "string",
            "description": "Human-readable name derived from the file stem, title-cased.",
            "example": "Senior Architect"
          },
          "path": {
            "type": "string",
            "description": "Absolute path to the agent file on disk.",
            "example": "/Users/oscar/.claude/agents/senior-architect.md"
          },
          "sizeBytes": {
            "type": "integer",
            "description": "File size in bytes.",
            "example": 11400
          }
        }
      },
      "AgentDetail": {
        "allOf": [
          { "$ref": "#/components/schemas/AgentInfo" },
          {
            "type": "object",
            "required": ["content"],
            "properties": {
              "content": {
                "type": "string",
                "description": "Full UTF-8 text content of the agent .md file.",
                "example": "# Senior Architect Agent\n\nYou are the Senior Architect..."
              }
            }
          }
        ]
      },
      "PromptGenerationRequest": {
        "type": "object",
        "description": "Parameters for generating an agent prompt and writing it to a temp file.",
        "required": ["agentId", "taskId", "spaceId"],
        "properties": {
          "agentId": {
            "type": "string",
            "description": "Kebab-case agent ID (must exist in ~/.claude/agents/).",
            "example": "senior-architect",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "taskId": {
            "type": "string",
            "description": "ID of the task to use as context for the TASK CONTEXT section.",
            "example": "abc-123"
          },
          "spaceId": {
            "type": "string",
            "description": "ID of the space that contains the task.",
            "example": "4391dcb8-1234-5678-abcd-ef0123456789"
          },
          "customInstructions": {
            "type": "string",
            "description": "Optional additional instructions appended at the end of the prompt.",
            "example": "Focus on scalability concerns.",
            "maxLength": 2000
          },
          "workingDirectory": {
            "type": "string",
            "description": "Optional override for the working directory included in PROJECT CONTEXT. If omitted, the server uses its own cwd.",
            "example": "/Users/oscar/projects/prism"
          }
        }
      },
      "PromptGenerationResponse": {
        "type": "object",
        "description": "Result of generating an agent prompt.",
        "required": ["promptPath", "promptPreview", "cliCommand", "estimatedTokens"],
        "properties": {
          "promptPath": {
            "type": "string",
            "description": "Absolute path to the written temp file. File is cleaned up by the server after 24 hours.",
            "example": "/Users/oscar/projects/prism/data/.prompts/prompt-1710795000000-abc123.md"
          },
          "promptPreview": {
            "type": "string",
            "description": "First 500 characters of the assembled prompt, for display in the preview modal.",
            "example": "## TASK CONTEXT\nTitle: Define TypeScript types for agent launcher\nType: research\n..."
          },
          "cliCommand": {
            "type": "string",
            "description": "The full CLI command string, ready to inject into the terminal PTY. Includes the file reference and any configured flags.",
            "example": "claude -p \"$(cat /Users/oscar/projects/prism/data/.prompts/prompt-1710795000000-abc123.md)\" --allowedTools \"Agent,Bash,Read,Write,Edit,Glob,Grep\""
          },
          "estimatedTokens": {
            "type": "integer",
            "description": "Rough token count estimate for the assembled prompt (characters / 4).",
            "example": 2400
          }
        }
      },
      "CliSettings": {
        "type": "object",
        "description": "CLI tool configuration for agent command generation.",
        "properties": {
          "tool": {
            "type": "string",
            "enum": ["claude", "opencode", "custom"],
            "description": "Which AI CLI tool to use.",
            "default": "claude"
          },
          "binary": {
            "type": "string",
            "description": "The binary name or full path. Defaults to the tool name. Required when tool is 'custom'.",
            "default": "claude",
            "example": "claude"
          },
          "flags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Flags prepended to the prompt argument.",
            "default": ["-p"],
            "example": ["-p"]
          },
          "promptFlag": {
            "type": "string",
            "description": "The flag that introduces the prompt argument.",
            "default": "-p",
            "example": "-p"
          },
          "fileInputMethod": {
            "type": "string",
            "enum": ["cat-subshell", "stdin-redirect", "flag-file"],
            "description": "How the prompt temp file is referenced in the CLI command. 'cat-subshell': $(cat /path), 'stdin-redirect': < /path, 'flag-file': --file /path.",
            "default": "cat-subshell"
          }
        }
      },
      "PipelineSettings": {
        "type": "object",
        "description": "Pipeline orchestration configuration.",
        "properties": {
          "autoAdvance": {
            "type": "boolean",
            "description": "When true, the next pipeline stage starts automatically after the current stage completes.",
            "default": true
          },
          "confirmBetweenStages": {
            "type": "boolean",
            "description": "When true, a confirmation toast is shown before advancing to the next stage, even in auto-advance mode.",
            "default": true
          },
          "stages": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "senior-architect",
                "ux-api-designer",
                "developer-agent",
                "qa-engineer-e2e"
              ]
            },
            "description": "Ordered list of agent IDs for the pipeline stages.",
            "default": [
              "senior-architect",
              "ux-api-designer",
              "developer-agent",
              "qa-engineer-e2e"
            ]
          }
        }
      },
      "PromptsSettings": {
        "type": "object",
        "description": "Prompt content configuration — controls which instruction blocks are included.",
        "properties": {
          "includeKanbanBlock": {
            "type": "boolean",
            "description": "Include the standard Kanban instructions block (server URL, space ID, MCP tool usage) in generated prompts.",
            "default": true
          },
          "includeGitBlock": {
            "type": "boolean",
            "description": "Include the standard Git instructions block (branch name, commit format) in generated prompts.",
            "default": true
          },
          "workingDirectory": {
            "type": "string",
            "description": "Working directory injected into PROJECT CONTEXT. Empty string means auto-detect from server cwd.",
            "default": "",
            "example": "/Users/oscar/projects/prism"
          },
          "customInstructions": {
            "type": "string",
            "description": "Custom instructions appended to the agent prompt. Markdown is supported and rendered with a MarkdownViewer component.",
            "default": "",
            "example": "Follow the PRISM design system when building UI components."
          }
        }
      },
      "LauncherSettings": {
        "type": "object",
        "description": "Full launcher settings object as stored in data/settings.json.",
        "required": ["cli", "pipeline", "prompts"],
        "properties": {
          "cli": { "$ref": "#/components/schemas/CliSettings" },
          "pipeline": { "$ref": "#/components/schemas/PipelineSettings" },
          "prompts": { "$ref": "#/components/schemas/PromptsSettings" }
        }
      },
      "LauncherSettingsPartial": {
        "type": "object",
        "description": "Partial settings for PUT — only provided fields are merged. Omitted fields retain their current values.",
        "properties": {
          "cli": {
            "type": "object",
            "description": "Partial CLI settings.",
            "properties": {
              "tool": {
                "type": "string",
                "enum": ["claude", "opencode", "custom"]
              },
              "binary": { "type": "string" },
              "flags": {
                "type": "array",
                "items": { "type": "string" }
              },
              "promptFlag": { "type": "string" },
              "fileInputMethod": {
                "type": "string",
                "enum": ["cat-subshell", "stdin-redirect", "flag-file"]
              }
            }
          },
          "pipeline": {
            "type": "object",
            "description": "Partial pipeline settings.",
            "properties": {
              "autoAdvance": { "type": "boolean" },
              "confirmBetweenStages": { "type": "boolean" },
              "stages": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "senior-architect",
                    "ux-api-designer",
                    "developer-agent",
                    "qa-engineer-e2e"
                  ]
                }
              }
            }
          },
          "prompts": {
            "type": "object",
            "description": "Partial prompt content settings.",
            "properties": {
              "includeKanbanBlock": { "type": "boolean" },
              "includeGitBlock": { "type": "boolean" },
              "workingDirectory": { "type": "string" }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "description": "Standard error envelope. Every error includes a code, a user-readable message, and a suggestion for resolution.",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "object",
            "required": ["code", "message", "suggestion"],
            "properties": {
              "code": {
                "type": "string",
                "description": "Machine-readable error code in SCREAMING_SNAKE_CASE.",
                "example": "AGENT_NOT_FOUND"
              },
              "message": {
                "type": "string",
                "description": "Human-readable explanation of what went wrong.",
                "example": "No agent named 'senior-architect' was found."
              },
              "suggestion": {
                "type": "string",
                "description": "Actionable guidance for the user to resolve the error.",
                "example": "Check that 'senior-architect.md' exists in ~/.claude/agents/."
              },
              "field": {
                "type": "string",
                "description": "For VALIDATION_ERROR only: the field name that failed validation.",
                "example": "agentId"
              }
            }
          }
        }
      }
    }
  },
